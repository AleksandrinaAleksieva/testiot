# ── Atlassian credentials ──────────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=you@company.com

# Personal API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3xFfGF0...

# Your Jira Cloud ID (visible in URLs: https://api.atlassian.com/ex/jira/<CLOUD_ID>/...)
# For shellyusa.atlassian.net it's: a45ac4b7-7db8-40a7-a5c6-1713fcbd8751
JIRA_CLOUD_ID=a45ac4b7-7db8-40a7-a5c6-1713fcbd8751

# Jira domain (without https://)
JIRA_DOMAIN=shellyusa.atlassian.net

# ── Server config ──────────────────────────────────────────────────────────────
PORT=3001

# Comma-separated list of allowed frontend origins (no trailing slash)
# For local dev: http://localhost:3000
# For production: https://your-portal.company.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
